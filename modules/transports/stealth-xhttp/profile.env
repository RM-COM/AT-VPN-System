TRANSPORT_XHTTP_TCP_KEEPALIVE_INTERVAL=0
TRANSPORT_XHTTP_TCP_KEEPALIVE_IDLE=300
TRANSPORT_XHTTP_TCP_USER_TIMEOUT=10000
