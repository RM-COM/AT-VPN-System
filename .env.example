# Переменные форка и источников
# Используются уже сейчас или зарезервированы под следующий этап пиннинга зависимостей.

REPO_SLUG=mozaroc/x-ui-pro
REPO_REF=master

# Необязательно. Если не задано, вычисляется из REPO_SLUG и REPO_REF.
# REPO_RAW_BASE=https://raw.githubusercontent.com/mozaroc/x-ui-pro/master

# Пользовательские ссылки проекта для web-sub страницы.
PROJECT_REPO_URL=https://github.com/RM-COM/AT-VPN-System
PROJECT_SUPPORT_URL=https://github.com/RM-COM/AT-VPN-System
PROJECT_DONATE_URL=https://github.com/RM-COM/AT-VPN-System

# Проверенные pinned-версии внешних бинарников.
# Для `amd64` эти версии уже зеркалированы в `vendor/releases/` и используются локально при запуске из клона репозитория.
XUI_REPO_SLUG=MHSanaei/3x-ui
XUI_VERSION=v2.8.11
SUB2SINGBOX_REPO_SLUG=legiz-ru/sub2sing-box
SUB2SINGBOX_VERSION=v0.0.9
SUB2SINGBOX_ARCH=amd64
